# HomeShield NGFW — environment configuration.
# Copy to .env and replace every value. Generate secrets with:
#   openssl rand -hex 32

# Database
DB_NAME=homeshield
DB_USER=homeshield
DB_PASS=change-me-strong-password
DB_ROOT_PASS=change-me-strong-root-password

# Auth — REQUIRED. Sessions are invalidated if this changes.
JWT_SECRET=change-me-openssl-rand-hex-32

# Enables the enforcement agent API (must match the agent's AGENT_TOKEN).
AGENT_TOKEN=change-me-openssl-rand-hex-32

# Optional: protect the /metrics endpoint. Leave blank to expose it openly
# (only do that on a trusted LAN / localhost-only Prometheus).
METRICS_TOKEN=

# Host port to publish the UI/API on.
APP_PORT=3000

# CORS origin for a separate Vite dev server (leave blank in production).
CORS_ORIGIN=

# Google Sign-In. Create an OAuth 2.0 Client ID (type: Web application) in the
# Google Cloud Console, add your console URL to "Authorized JavaScript origins",
# and paste the client ID here. Leave blank to disable Google sign-in.
GOOGLE_CLIENT_ID=

