<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Do NOT rewrite API requests — pass through to the Node.js server
  RewriteRule ^api(/|$) - [L]

  # Serve existing files/directories as-is
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # For all other routes, serve the React SPA
  RewriteRule . /index.html [L]
</IfModule>
